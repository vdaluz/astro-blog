---
interface Props {
  text: string;
  align?: 'left' | 'center' | 'right';
  color?: 'blue' | 'gray';
}

const { text, align = 'left', color = 'blue' } = Astro.props;

const alignClasses = {
  left: 'text-left',
  center: 'text-center',
  right: 'text-right',
};

const colorClasses = {
  blue: 'text-accent',
  gray: 'text-muted',
};
---

<div class={`mb-4 ${alignClasses[align]}`}>
  <span
    class={`inline-block text-sm uppercase tracking-wider font-semibold ${colorClasses[color]}`}
  >
    {text}
  </span>
</div>
