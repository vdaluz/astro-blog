---
import type { BlogPostLike } from '../lib/types';

interface Props {
  posts: BlogPostLike[];
  /** Route prefix posts live under. Defaults to "/blog". */
  base?: string;
}

const { posts, base = '/blog' } = Astro.props;
---

<section aria-label="Related reading" class="mt-16 pt-8 border-t border-border">
  <h2 class="text-2xl font-bold text-fg mb-8">Related reading</h2>
  <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
    {
      posts.map((post) => (
        <article class="bg-surface rounded-xl shadow overflow-hidden hover:shadow-lg transition-all duration-300 flex flex-col">
          {post.data.heroImage && (
            <a href={`${base}/${post.id}`}>
              <img
                src={post.data.heroImage}
                alt={post.data.title}
                class="w-full h-40 object-cover"
              />
            </a>
          )}
          <div class="p-6 flex flex-col flex-grow">
            <div class="inline-block self-start px-3 py-1 bg-accent-soft text-accent rounded-full text-xs font-medium mb-3">
              {post.data.category}
            </div>
            <h3 class="text-lg font-bold text-fg mb-3 hover:text-accent transition-colors leading-snug">
              <a href={`${base}/${post.id}`}>{post.data.title}</a>
            </h3>
            <p class="text-muted text-sm leading-relaxed mb-4 flex-grow line-clamp-3">
              {post.data.description}
            </p>
            <div class="flex items-center justify-between mt-auto">
              <time datetime={post.data.pubDate.toISOString()} class="text-xs text-muted">
                {post.data.pubDate.toLocaleDateString('en-US', {
                  year: 'numeric',
                  month: 'short',
                  day: 'numeric',
                })}
              </time>
              <a
                href={`${base}/${post.id}`}
                class="inline-flex items-center text-accent text-sm font-semibold hover:text-accent-strong transition-colors group"
                aria-label={`Read ${post.data.title}`}
              >
                Read
                <svg
                  class="w-3 h-3 ml-1 transform group-hover:translate-x-1 transition-transform duration-300"
                  viewBox="0 0 20 20"
                  fill="currentColor"
                  aria-hidden="true"
                >
                  <path
                    fill-rule="evenodd"
                    d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z"
                    clip-rule="evenodd"
                  />
                </svg>
              </a>
            </div>
          </div>
        </article>
      ))
    }
  </div>
</section>
